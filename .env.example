# ─────────────────────────────────────────────
# NutriSense — Local Development Setup
# Copy this file to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Use either DATABASE_URL (local Postgres) or SUPABASE_DB_URL (Supabase Session Pooler)
# Supabase: Go to Project Settings → Database → Connection pooling → Session mode → copy URI
DATABASE_URL=postgresql://user:password@localhost:5432/nutrisense

# Optional: Supabase pooled connection (takes priority over DATABASE_URL if set)
# SUPABASE_DB_URL=postgresql://postgres.xxxx:password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── Session ───────────────────────────────────
# Any long random string — generate with: openssl rand -base64 32
SESSION_SECRET=your-super-secret-session-key-change-this

# ── Gemini AI ─────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
AI_INTEGRATIONS_GEMINI_API_KEY=your-gemini-api-key-here

# Leave this blank for default Google API endpoint
# Only set if you have a custom proxy URL
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ── Node ──────────────────────────────────────
NODE_ENV=development
